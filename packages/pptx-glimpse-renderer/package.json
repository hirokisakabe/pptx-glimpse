{
  "name": "pptx-glimpse-renderer",
  "version": "0.1.0",
  "description": "SVG/PNG renderer for pptx-glimpse intermediate model",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hirokisakabe/pptx-glimpse.git",
    "directory": "packages/pptx-glimpse-renderer"
  },
  "author": "hirokisakabe",
  "license": "MIT",
  "dependencies": {
    "opentype.js": "^1.3.4",
    "sharp": "^0.34.5"
  }
}

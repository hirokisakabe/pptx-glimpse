{
  "name": "@pptx-glimpse/document",
  "version": "0.3.0",
  "description": "PptxSourceModel and OOXML document foundation for pptx-glimpse.",
  "keywords": [
    "pptx",
    "powerpoint",
    "ooxml",
    "presentation",
    "document"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {

{
  "name": "pptx-glimpse-skeleton",
  "version": "0.0.0",
  "private": true,
  "description": "Main pptx-glimpse package (parser + public API). Will replace the root-level pptx-glimpse package in a follow-up issue.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "dependencies": {
    "@pptx-glimpse/document": "workspace:*",
    "fast-xml-parser": "^5.7.3",
    "fflate": "^0.8.2",
    "pptx-glimpse-renderer": "workspace:*"
  }
}
